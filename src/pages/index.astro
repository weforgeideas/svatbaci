</Layout>

<script>
  // Scroll pulse in hero
  const pulse = document.getElementById('scroll-pulse');
  let p = -100, dir = 1;
  const tick = () => {
    p += dir * 1.5;
    if (p >= 100) dir = -1;
    if (p <= -100) dir = 1;
    if (pulse) pulse.style.transform = `translateY(${p}%)`;
    requestAnimationFrame(tick);
  };
  tick();
</script>

<style>
  input, textarea { outline: none; }
  img { transition: opacity 0.4s ease; }
  ::selection { background: #C8900A; color: #1A1714; }
</style>
